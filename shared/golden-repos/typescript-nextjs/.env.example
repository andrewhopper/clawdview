# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
NEXT_PUBLIC_ENV=local

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_APP_NAME=Next.js App
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===========================================
# Feature Flags
# ===========================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: ENABLE_DEBUG=true, ENABLE_ANALYTICS=false
# Dev: ENABLE_DEBUG=true, ENABLE_ANALYTICS=false
# Integration: ENABLE_DEBUG=false, ENABLE_ANALYTICS=false
# Stage: ENABLE_DEBUG=false, ENABLE_ANALYTICS=true
# Prod: ENABLE_DEBUG=false, ENABLE_ANALYTICS=true
