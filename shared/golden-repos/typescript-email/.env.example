# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
ENV=local

# ===========================================
# Email Provider (Required)
# ===========================================
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ===========================================
# Sender Settings
# ===========================================
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_FROM_NAME=My App

# ===========================================
# Application Settings
# ===========================================
APP_URL=http://localhost:3000

# ===========================================
# Feature Flags
# ===========================================
ENABLE_EMAIL_LOGGING=true
ENABLE_EMAIL_PREVIEW=true

# ===========================================
# Development Settings
# ===========================================
# Redirect all emails to this address in local/dev
PREVIEW_EMAIL=developer@example.com

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: ENABLE_EMAIL_LOGGING=true, ENABLE_EMAIL_PREVIEW=true
# Dev: ENABLE_EMAIL_LOGGING=true, ENABLE_EMAIL_PREVIEW=true
# Integration: ENABLE_EMAIL_LOGGING=true, ENABLE_EMAIL_PREVIEW=false
# Stage: ENABLE_EMAIL_LOGGING=false, ENABLE_EMAIL_PREVIEW=false
# Prod: ENABLE_EMAIL_LOGGING=false, ENABLE_EMAIL_PREVIEW=false
