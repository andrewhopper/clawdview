# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
ENV=local

# ===========================================
# Application Settings
# ===========================================
APP_NAME=fastapi-backend
APP_VERSION=0.1.0
DEBUG=true

# ===========================================
# Server Settings
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ===========================================
# Logging
# ===========================================
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Format: json (production), console (local development)
LOG_FORMAT=console

# ===========================================
# CORS
# ===========================================
# Comma-separated list or JSON array
CORS_ORIGINS=["http://localhost:3000"]

# ===========================================
# API Settings
# ===========================================
API_PREFIX=/api/v1

# ===========================================
# Database (Optional)
# ===========================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# ===========================================
# Redis/Cache (Optional)
# ===========================================
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# Feature Flags
# ===========================================
ENABLE_METRICS=false
ENABLE_TRACING=false
ENABLE_DOCS=true

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: DEBUG=true, LOG_FORMAT=console, ENABLE_DOCS=true
# Dev: DEBUG=true, LOG_FORMAT=json, ENABLE_DOCS=true
# Integration: DEBUG=false, LOG_FORMAT=json, ENABLE_DOCS=true
# Stage: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true
# Prod: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true, ENABLE_DOCS=false
