# ===========================================
# Library Configuration
# ===========================================
# All variables prefixed with MYLIB_

# Environment: local, dev, integration, stage, prod
MYLIB_ENV=local

# ===========================================
# Logging
# ===========================================
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
MYLIB_LOG_LEVEL=INFO
# Format: json (production), console (local development)
MYLIB_LOG_FORMAT=console

# ===========================================
# Feature Flags
# ===========================================
MYLIB_ENABLE_DEBUG_LOGGING=false
MYLIB_ENABLE_METRICS=false

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: LOG_FORMAT=console, ENABLE_DEBUG_LOGGING=true
# Dev: LOG_FORMAT=json, ENABLE_DEBUG_LOGGING=true
# Integration: LOG_FORMAT=json
# Stage: LOG_FORMAT=json, ENABLE_METRICS=true
# Prod: LOG_FORMAT=json, ENABLE_METRICS=true
