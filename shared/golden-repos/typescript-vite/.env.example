# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
VITE_ENV=local

# ===========================================
# Application Settings
# ===========================================
VITE_APP_NAME=vite-app
VITE_APP_VERSION=0.1.0
VITE_DEBUG=true

# ===========================================
# API Settings
# ===========================================
VITE_API_URL=http://localhost:3000/api

# ===========================================
# Logging
# ===========================================
# Level: debug, info, warn, error
VITE_LOG_LEVEL=info

# ===========================================
# Feature Flags
# ===========================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEVTOOLS=true

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: DEBUG=true, ENABLE_DEVTOOLS=true
# Dev: DEBUG=true, ENABLE_DEVTOOLS=true
# Integration: DEBUG=false, ENABLE_DEVTOOLS=false
# Stage: DEBUG=false, ENABLE_ANALYTICS=true
# Prod: DEBUG=false, ENABLE_ANALYTICS=true
