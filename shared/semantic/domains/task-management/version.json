{
  "domain": "task-management",
  "version": "1.2.0",
  "description": "Task management primitives - todos, categories, tags, projects, deadlines, attachments, and media",
  "languages": ["typescript", "python"],
  "changelog": {
    "1.2.0": "Extend work-item abstract base domain for shared primitives",
    "1.1.0": "Add attachments, embedded media, and comments support",
    "1.0.0": "Initial release - complete task management domain with todos, projects, categories, tags, deadlines, recurrence, and activity tracking"
  },
  "entities": [
    "Todo",
    "Subtask",
    "Project",
    "Category",
    "Tag",
    "TodoTag",
    "Deadline",
    "Reminder",
    "TaskRecurrence",
    "Attachment",
    "EmbeddedMedia",
    "Comment",
    "TodoActivity",
    "SavedFilter",
    "FilterCriteria",
    "DateRangeFilter"
  ],
  "actions": [
    "CreateTodo",
    "UpdateTodo",
    "CompleteTodo",
    "DeleteTodo",
    "AddSubtask",
    "ToggleSubtask",
    "TagTodo",
    "UntagTodo",
    "ListTodos",
    "GetTodosByProject",
    "GetOverdueTodos",
    "CreateProject",
    "ArchiveProject",
    "CreateCategory",
    "CreateTag",
    "AddAttachment",
    "RemoveAttachment",
    "EmbedMedia",
    "AddComment",
    "UpdateComment",
    "DeleteComment"
  ],
  "enums": [
    "TodoStatus",
    "Priority",
    "ProjectStatus",
    "RecurrencePattern",
    "DayOfWeek",
    "CompletionBehavior",
    "ReminderType",
    "ReminderChannel",
    "AttachmentType",
    "MediaType",
    "DescriptionFormat",
    "ActivityAction",
    "SortField",
    "SortDirection",
    "GroupField",
    "DateRangeType"
  ],
  "dependencies": ["core", "work-item"],
  "extends": "work-item",
  "w3c_standards": ["RDF", "OWL", "SHACL"]
}
