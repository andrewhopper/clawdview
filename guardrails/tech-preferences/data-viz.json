          "useCases": [
            "documentation",
            "automatic diagrams",
            "CI/CD",
            "flowcharts",
            "sequence diagrams"
          ],
          "docsUrl": "https://mermaid.js.org/intro/",
          "examplesUrl": "https://mermaid.js.org/ecosystem/tutorials.html"
        },
        {
          "rank": 2,
          "name": "ReactFlow",
          "version": "11.x",
          "rationale": "React-native, interactive node-based UIs, customizable, drag-and-drop",
