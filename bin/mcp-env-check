#!/usr/bin/env bash
# File UUID: 0b1c2d3e-4f5g-6h7i-8j9k-0l1m2n3o4p5q

# MCP Environment Variables Check
# Validates that all required environment variables for MCP servers are set

set -eo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track status
all_ok=true

echo "═══════════════════════════════════════════════════════════"
echo "  MCP ENVIRONMENT VARIABLES CHECK"
echo "═══════════════════════════════════════════════════════════"
echo

# Required environment variables for MCP servers
declare -A required_vars=(
    ["BRAVE_SEARCH_API_KEY"]="Brave Search MCP Server"
    ["PERPLEXITY_API_KEY"]="Perplexity MCP Server"
    ["FIRECRAWL_API_KEY"]="Firecrawl MCP Server"
    ["NEO4J_URI"]="Graph RAG MCP Server"
    ["NEO4J_PASSWORD"]="Graph RAG MCP Server"
)

# Optional but recommended
declare -A optional_vars=(
    ["ANTHROPIC_API_KEY"]="Claude API access"
    ["OPENAI_API_KEY"]="OpenAI integrations"
)

echo "┌─ REQUIRED ENVIRONMENT VARIABLES"
echo "│"

for var in "${!required_vars[@]}"; do
    # Use indirect expansion with default value to avoid unbound variable error
    var_value="${!var:-}"
    if [ -z "$var_value" ]; then
        echo -e "│ ${RED}✗${NC} $var (missing)"
        echo "│   Used by: ${required_vars[$var]}"
        all_ok=false
    else
        # Mask the value for security
        masked="${var_value:0:4}...${var_value: -4}"
        echo -e "│ ${GREEN}✓${NC} $var (set: $masked)"
    fi
done

echo "│"
echo "└─"
echo

echo "┌─ OPTIONAL ENVIRONMENT VARIABLES"
echo "│"

for var in "${!optional_vars[@]}"; do
    var_value="${!var:-}"
    if [ -z "$var_value" ]; then
        echo -e "│ ${YELLOW}○${NC} $var (not set)"
        echo "│   Used by: ${optional_vars[$var]}"
    else
        masked="${var_value:0:4}...${var_value: -4}"
        echo -e "│ ${GREEN}✓${NC} $var (set: $masked)"
    fi
done

echo "│"
echo "└─"
echo

if [ "$all_ok" = false ]; then
    echo "┌─ ACTIONS REQUIRED"
    echo "│"
    echo "│ Missing environment variables detected!"
    echo "│"
    echo "│ To fix:"
    echo "│ 1. Add to your shell profile (~/.zshrc or ~/.bashrc):"
    echo "│    export BRAVE_SEARCH_API_KEY='your-key-here'"
    echo "│    export PERPLEXITY_API_KEY='your-key-here'"
    echo "│    export FIRECRAWL_API_KEY='your-key-here'"
    echo "│    export NEO4J_URI='bolt://localhost:7687'"
    echo "│    export NEO4J_PASSWORD='your-password'"
    echo "│"
    echo "│ 2. Reload your shell:"
    echo "│    source ~/.zshrc"
    echo "│"
    echo "│ 3. Restart Claude Code"
    echo "│"
    echo "│ Alternatively, add to MCP config env block:"
    echo "│    ~/.claude/settings.json → mcpServers → serverName → env"
    echo "│"
    echo "└─"
    echo
    exit 1
else
    echo -e "${GREEN}✓${NC} All required environment variables are set"
    echo
    exit 0
fi
