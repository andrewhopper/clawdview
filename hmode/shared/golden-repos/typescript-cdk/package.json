{
  "name": "typescript-cdk-template",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "deploy:dev": "ENV=dev cdk deploy --all",
    "deploy:stage": "ENV=stage cdk deploy --all",
    "deploy:prod": "ENV=prod cdk deploy --all --require-approval broadening",
    "diff": "cdk diff",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint lib bin --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.130.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  }
}
