# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
NODE_ENV=local

# ===========================================
# Application Settings
# ===========================================
APP_NAME=nodejs-app
APP_VERSION=0.1.0
DEBUG=true

# ===========================================
# Logging
# ===========================================
# Level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
# Format: json (production), pretty (local development)
LOG_FORMAT=pretty

# ===========================================
# Server Settings
# ===========================================
PORT=3000
HOST=0.0.0.0

# ===========================================
# Database (Optional)
# ===========================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# ===========================================
# Redis (Optional)
# ===========================================
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# Feature Flags
# ===========================================
ENABLE_METRICS=false
ENABLE_TRACING=false

# ===========================================
# Environment-Specific Defaults
# ===========================================
# Local: DEBUG=true, LOG_FORMAT=pretty
# Dev: DEBUG=true, LOG_FORMAT=json
# Integration: DEBUG=false, LOG_FORMAT=json
# Stage: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true
# Prod: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true, ENABLE_TRACING=true
