# ===========================================
# React Component Library Configuration
# ===========================================
# Note: For libraries, configuration is typically done
# programmatically by the consuming application.

# When using the library:
# import { configure } from 'react-component-library';
# configure({ env: 'prod', debug: false });

# ===========================================
# Development Environment
# ===========================================
# For Storybook or local development server
VITE_ENV=local
VITE_DEBUG=true
VITE_ENABLE_METRICS=false

# ===========================================
# Environment Options
# ===========================================
# local - Local development
# dev - Development environment
# integration - Integration testing
# stage - Staging/pre-production
# prod - Production
