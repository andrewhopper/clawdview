# ===========================================
# Environment Configuration
# ===========================================
# Options: local, dev, integration, stage, prod
ENV=local

# ===========================================
# Application Settings
# ===========================================
APP_NAME=python-script
APP_VERSION=0.1.0
DEBUG=true

# ===========================================
# Logging
# ===========================================
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Format: json (production), console (local development)
LOG_FORMAT=console

# ===========================================
# Paths
# ===========================================
DATA_DIR=./data
OUTPUT_DIR=./output

# ===========================================
# Feature Flags
# ===========================================
ENABLE_METRICS=false
ENABLE_TRACING=false

# ===========================================
# Environment-Specific Overrides
# ===========================================
# Local: DEBUG=true, LOG_FORMAT=console
# Dev: DEBUG=true, LOG_FORMAT=json
# Integration: DEBUG=false, LOG_FORMAT=json
# Stage: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true
# Prod: DEBUG=false, LOG_FORMAT=json, ENABLE_METRICS=true, ENABLE_TRACING=true
