# AWS Configuration
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Deployment Stage
STAGE_NAME=dev

# Cognito Configuration
# By default, uses the shared auth.b.lfg.new user pool
# Set COGNITO_CREATE_NEW=true to create a new dedicated user pool instead
COGNITO_CREATE_NEW=false

# Shared auth.b.lfg.new user pool (defaults)
COGNITO_USER_POOL_ID=us-east-1_p0fQSZLEG
COGNITO_USER_POOL_ARN=arn:aws:cognito-idp:us-east-1:507745175693:userpool/us-east-1_p0fQSZLEG

# App Client ID (created during deployment or use existing)
COGNITO_USER_POOL_CLIENT_ID=
