# API Gateway URL (from CDK output)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Cognito Configuration
# The shared auth.b.lfg.new user pool is used by default
# User Pool ID defaults to: us-east-1_p0fQSZLEG
VITE_USER_POOL_ID=us-east-1_p0fQSZLEG

# App Client ID (REQUIRED - get this from CDK output or Cognito console)
# This is specific to your application
VITE_USER_POOL_CLIENT_ID=

# Cognito domain for hosted UI (defaults to auth.b.lfg.new)
VITE_COGNITO_DOMAIN=auth.b.lfg.new
