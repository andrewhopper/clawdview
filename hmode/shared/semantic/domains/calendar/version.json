{
  "domain": "calendar",
  "version": "1.0.0",
  "description": "Calendar and scheduling primitives - events, meetings, attendees, RSVPs, and availability",
  "languages": ["typescript", "python"],
  "changelog": {
    "1.0.0": "Initial release - complete calendar domain with events, meetings, attendees, RSVP, availability, and scheduling links"
  },
  "entities": [
    "Calendar",
    "Event",
    "Attendee",
    "RSVP",
    "Meeting",
    "AgendaItem",
    "MeetingActionItem",
    "Availability",
    "BusyBlock",
    "SchedulingLink",
    "Booking",
    "EventLocation",
    "ConferenceData",
    "EventRecurrence",
    "EventReminder",
    "EventAttachment",
    "ProposedTime",
    "BookingQuestion",
    "BookingAnswer"
  ],
  "actions": [
    "CreateCalendar",
    "CreateEvent",
    "UpdateEvent",
    "DeleteEvent",
    "InviteAttendee",
    "RemoveAttendee",
    "RespondToEvent",
    "GetAvailability",
    "FindAvailableSlots",
    "CreateSchedulingLink",
    "BookAppointment",
    "CancelBooking",
    "CreateMeeting",
    "AddActionItem"
  ],
  "enums": [
    "CalendarVisibility",
    "SyncSource",
    "EventType",
    "EventStatus",
    "EventVisibility",
    "DescriptionFormat",
    "AttendeeRole",
    "ResponseStatus",
    "MeetingType",
    "AgendaItemStatus",
    "ActionItemStatus",
    "LocationType",
    "ConferenceType",
    "RecurrencePattern",
    "DayOfWeek",
    "ReminderMethod",
    "BusyReason",
    "BookingStatus",
    "QuestionType",
    "UpdateScope"
  ],
  "dependencies": ["core", "auth", "notification"],
  "cross_domain_references": ["task-management:Todo"],
  "w3c_standards": ["RDF", "OWL", "SHACL", "iCalendar (RFC 5545)"]
}
