{
  "name": "@hopperlabs/project-status-tracker",
  "version": "0.1.0",
  "description": "Event-sourced status tracking for project portfolio manager",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
