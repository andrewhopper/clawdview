  "categories": {
    "frontend_frameworks": {
      "description": "JavaScript/TypeScript frontend frameworks",
      "preferences": [
        {
          "rank": 1,
          "name": "Next.js",
          "version": "15.x (stable with React 19)",
          "rationale": "Full-stack React with App Router, Server Components, built-in API routes, excellent DX, React 19 stable support",
          "useCases": [
            "web apps",
            "dashboards",
            "marketing sites",
            "full-stack projects"
          ],
          "docsUrl": "https://nextjs.org/docs",
          "examplesUrl": "https://github.com/vercel/next.js/tree/canary/examples"
        },
        {
          "rank": 2,
          "name": "Vite + React",
          "version": "6.x + React 19.x (stable)",
          "rationale": "Fast HMR, simple SPAs, lightweight, ESM-first, no backend needed, React 19 stable support",
          "useCases": [
            "simple SPAs",
            "client-only apps",
            "fast prototypes",
            "embedded widgets"
          ],
          "docsUrl": "https://vitejs.dev/guide/",
          "examplesUrl": "https://github.com/vitejs/vite/tree/main/playground"
        },
        {
          "rank": 3,
          "name": "Expo",
          "version": "SDK 51+",
          "rationale": "React Native for mobile, managed workflow, cross-platform iOS/Android",
          "useCases": [
            "mobile apps",
            "cross-platform native",
            "iOS/Android"
          ],
          "docsUrl": "https://docs.expo.dev/",
          "examplesUrl": "https://github.com/expo/examples"
        }
      ]
    },
