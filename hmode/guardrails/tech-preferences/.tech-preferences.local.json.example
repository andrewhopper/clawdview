{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project-Level Tech Preferences Override",
  "description": "Override global tech preferences for this project. Copy to .tech-preferences.local.json in project root.",
  "version": "1.0.0",
  "overrides": {
    "frontend_frameworks": {
      "preferences": [
        {
          "rank": 1,
          "name": "Vite",
          "version": "5.x",
          "rationale": "This project uses Vite instead of Next.js for faster builds",
          "useCases": ["SPA", "rapid prototyping"],
          "docsUrl": "https://vitejs.dev/guide/",
          "examplesUrl": "https://github.com/vitejs/vite/tree/main/packages/create-vite"
        }
      ]
    },
    "databases": {
      "preferences": [
        {
          "rank": 1,
          "name": "SQLite",
          "version": "3.x",
          "rationale": "Lightweight local development, embedded database",
          "useCases": ["local dev", "prototypes", "embedded"],
          "docsUrl": "https://www.sqlite.org/docs.html",
          "examplesUrl": "https://www.sqlite.org/quickstart.html"
        }
      ]
    }
  },
  "additions": {
    "custom_category": {
      "description": "Custom category specific to this project",
      "preferences": [
        {
          "rank": 1,
          "name": "Custom Tool",
          "version": "1.0.0",
          "rationale": "Project-specific tool not in global preferences",
          "useCases": ["special use case"],
          "docsUrl": "https://example.com/docs",
          "examplesUrl": "https://example.com/examples"
        }
      ]
    }
  },
  "notes": [
    "Place this file as .tech-preferences.local.json in your project root",
    "This file is gitignored by default - each developer can customize",
    "Overrides replace global preferences for the specified category",
    "Additions create new categories not in global preferences",
    "Use for: prototypes, experiments, client-specific tech requirements"
  ]
}
