#!/usr/bin/env bash
# install-hooks: Install git hooks for hmode (post-checkout + post-merge)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HMODE_DIR="$(dirname "$SCRIPT_DIR")"
PROJECT_ROOT="$(dirname "$HMODE_DIR")"
HOOK_DIR="$PROJECT_ROOT/.git/hooks"

if [ ! -d "$HOOK_DIR" ]; then
  echo "Error: .git/hooks not found at $HOOK_DIR"
  exit 1
fi

HMODE_INIT_LINE='[ -f "hmode/bin/hmode-init" ] && ./hmode/bin/hmode-init --quiet'

install_hook() {
  local hook_name="$1"
  local hook_file="$HOOK_DIR/$hook_name"

  if [ -f "$hook_file" ]; then
    if grep -qF "hmode-init" "$hook_file"; then
      echo "  $hook_name: already configured"
      return
    fi
    echo "" >> "$hook_file"
    echo "$HMODE_INIT_LINE" >> "$hook_file"
    echo "  $hook_name: appended hmode-init"
  else
    cat > "$hook_file" << HOOK
#!/bin/bash
$HMODE_INIT_LINE
HOOK
    chmod +x "$hook_file"
    echo "  $hook_name: created"
  fi
}

echo "Installing hmode git hooks..."
install_hook "post-checkout"
install_hook "post-merge"
echo "Done."
