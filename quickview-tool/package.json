{
  "name": "clawdview",
  "version": "1.0.0",
  "description": "Universal rapid prototyping tool for instant code preview",
  "main": "server.js",
  "bin": {
    "quickview": "./bin/quickview.js"
  },
  "scripts": {
    "start": "node server.js",
    "install-global": "npm install -g .",
    "dev": "nodemon server.js",
    "preview": "quickview start",
    "preview:port": "quickview start --port",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report tests/playwright-report"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^11.0.0",
    "exif-parser": "^0.1.12",
    "express": "^4.18.2",
    "highlight.js": "^11.8.0",
    "live-server": "^1.2.2",
    "marked": "^5.1.1",
    "open": "^9.1.0",
    "socket.io": "^4.7.2"
  },
  "optionalDependencies": {
    "@ngrok/ngrok": "^1.4.1",
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "preview",
    "prototyping",
    "development",
    "hot-reload"
  ],
  "author": "Andrew Hopper",
  "license": "MIT"
}
