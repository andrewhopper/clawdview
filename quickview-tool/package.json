{
  "name": "clawdview",
  "version": "2.0.0",
  "description": "Universal rapid prototyping tool for instant code preview",
  "main": "dist/server/server.js",
  "bin": {
    "quickview": "./bin/quickview.js"
  },
  "scripts": {
    "dev": "concurrently \"tsx watch src/server/server.ts\" \"vite\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "start": "node dist/server/server.js",
    "preview": "quickview start",
    "preview:port": "quickview start --port",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report tests/playwright-report"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^11.0.0",
    "exif-parser": "^0.1.12",
    "express": "^4.18.2",
    "highlight.js": "^11.8.0",
    "lucide-react": "^0.577.0",
    "marked": "^5.1.1",
    "open": "^9.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "@ngrok/ngrok": "^1.4.1",
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "preview",
    "prototyping",
    "development",
    "hot-reload"
  ],
  "author": "Andrew Hopper",
  "license": "MIT"
}
