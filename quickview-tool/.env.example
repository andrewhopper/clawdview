# S3 Asset Sharing Configuration
# Copy this file to .env and fill in your values.

# Required: S3 bucket name
QV_S3_BUCKET=

# Optional: AWS region (default: us-east-1)
# AWS_REGION=us-east-1

# Optional: explicit credentials (falls back to AWS SDK default chain)
# QV_S3_ACCESS_KEY_ID=
# QV_S3_SECRET_ACCESS_KEY=

# Optional: S3 key prefix (default: quickview-shares)
# QV_S3_PREFIX=quickview-shares

# Optional: project name for organizing assets (default: directory name)
# QV_PROJECT_NAME=my-project

# Optional: pre-signed URL expiration in seconds (default: 3600, max: 604800)
# QV_S3_URL_EXPIRES=3600

# Optional: custom S3-compatible endpoint (e.g. MinIO, LocalStack)
# QV_S3_ENDPOINT=http://localhost:9000
